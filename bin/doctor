#!/usr/bin/env python3
"""Self-audit: PYTHONPATH=. python3 bin/doctor [--offline]

Exit 0 when no FAIL (warns allowed), 1 otherwise.
"""
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from core import doctor_checks as dc  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Etherwise v3 self-audit")
    parser.add_argument("--offline", action="store_true",
                        help="skip network checks (/v1/models)")
    args = parser.parse_args()

    counts = {"PASS": 0, "WARN": 0, "FAIL": 0, "SKIP": 0}
    for group, fn in dc.ALL_CHECKS:
        checks = fn(offline=args.offline) if fn is dc.check_models_api \
            else fn()
        for c in checks:
            counts[c.status] = counts.get(c.status, 0) + 1
            print(f"[{c.status:4}] {c.name:<24} {c.detail}")

    print("-" * 64)
    print(" · ".join(f"{n} {s}" for s, n in counts.items()))
    return 1 if counts["FAIL"] else 0


if __name__ == "__main__":
    sys.exit(main())
