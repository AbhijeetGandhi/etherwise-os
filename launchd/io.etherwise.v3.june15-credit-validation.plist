<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>io.etherwise.v3.june15-credit-validation</string>
  <!-- Framework Python (FDA-granted); NO WorkingDirectory and logs OUTSIDE
       ~/Desktop — both required or launchd fails to spawn (exit 78) or Python
       dies on '.' in sys.path. Proven by v2's plists. -->
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework/Versions/3.9/Resources/Python.app/Contents/MacOS/Python</string>
    <string>/Users/abhijeet/Desktop/Etherwise/etherwise-v3/bin/june15_credit_check.py</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    <key>PYTHONPATH</key><string>/Users/abhijeet/Desktop/Etherwise/etherwise-v3</string>
  </dict>
  <key>StandardOutPath</key><string>/Users/abhijeet/Library/Logs/Etherwise-v3/june15-credit-validation.log</string>
  <key>StandardErrorPath</key><string>/Users/abhijeet/Library/Logs/Etherwise-v3/june15-credit-validation.log</string>
  <key>RunAtLoad</key><false/>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Month</key><integer>6</integer>
    <key>Day</key><integer>15</integer>
    <key>Hour</key><integer>12</integer>
    <key>Minute</key><integer>10</integer>
  </dict>
</dict>
</plist>
